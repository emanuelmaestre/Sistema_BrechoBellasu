# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ─── Autenticação JWT ─────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 64
JWT_SECRET=

# ─── Melhor Envio (fretes / etiquetas) ───────────────────────────────────────
# MELHOR_ENVIO_ENV: "sandbox" ou "producao"
MELHOR_ENVIO_TOKEN=
MELHOR_ENVIO_ENV=sandbox
MELHOR_ENVIO_CEP_ORIGEM=
# Dimensões padrão dos pacotes (cm / kg)
MELHOR_ENVIO_ALTURA=
MELHOR_ENVIO_LARGURA=
MELHOR_ENVIO_COMPRIMENTO=
MELHOR_ENVIO_PESO=

# ─── Z-API (WhatsApp) ─────────────────────────────────────────────────────────
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=
# Segredo para proteger /api/webhooks/zapi. Envie como Authorization: Bearer <segredo>
# ou como header x-zapi-webhook-secret.
ZAPI_WEBHOOK_SECRET=

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
# Opcional: modelo usado para variar mensagens de consentimento. Se ausente, usa gpt-4o-mini.
OPENAI_CONSENT_MODEL=
# Opcional: modelo de visão para ler a foto do caderno na live. Se ausente, usa gpt-4o.
OPENAI_VISION_MODEL=

# ─── Vercel (deploy via API) ──────────────────────────────────────────────────
VERCEL_TOKEN=
VERCEL_ACCESS_TOKEN=

# ─── Cron jobs ────────────────────────────────────────────────────────────────
# Obrigatório em produção. Envie como Authorization: Bearer <segredo>
# ou como header x-cron-secret.
CRON_SECRET=
# Limites do cron de aniversario para evitar timeout em producao.
ANIVERSARIO_CRON_MAX_ENVIOS=8
ANIVERSARIO_CRON_MAX_RUNTIME_MS=45000
SYNC_ETIQUETAS_CRON_MAX_ITENS=40
SYNC_ETIQUETAS_CRON_MAX_RUNTIME_MS=50000
