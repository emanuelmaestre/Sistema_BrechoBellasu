# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ─── Autenticação JWT ─────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 64
JWT_SECRET=

# ─── Asaas (cobranças/pagamentos) ────────────────────────────────────────────
# Produção: https://api.asaas.com/v3  |  Sandbox: https://sandbox.asaas.com/api/v3
ASAAS_TOKEN=
ASAAS_URL=https://sandbox.asaas.com/api/v3

# ─── Melhor Envio (fretes / etiquetas) ───────────────────────────────────────
# MELHOR_ENVIO_ENV: "sandbox" ou "producao"
MELHOR_ENVIO_TOKEN=
MELHOR_ENVIO_ENV=sandbox
MELHOR_ENVIO_CEP_ORIGEM=
# Dimensões padrão dos pacotes (cm / kg)
MELHOR_ENVIO_ALTURA=
MELHOR_ENVIO_LARGURA=
MELHOR_ENVIO_COMPRIMENTO=
MELHOR_ENVIO_PESO=

# ─── Z-API (WhatsApp) ─────────────────────────────────────────────────────────
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# ─── Resend (e-mail transacional) ────────────────────────────────────────────
RESEND_API_KEY=

# ─── Anthropic (Claude — leitura de fotos do caderno na live) ────────────────
# Crie em https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
# Opcional: modelo usado para variar mensagens de consentimento. Se ausente, usa gpt-4o-mini.
OPENAI_CONSENT_MODEL=

# ─── Vercel (deploy via API) ──────────────────────────────────────────────────
VERCEL_TOKEN=
VERCEL_ACCESS_TOKEN=

# ─── Cron jobs ────────────────────────────────────────────────────────────────
# Adicione este valor como header "x-cron-secret" nas chamadas automáticas
CRON_SECRET=
